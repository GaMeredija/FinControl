generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  name         String        @db.VarChar(120)
  email        String        @unique @db.VarChar(180)
  passwordHash String        @map("password_hash") @db.Text
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  accounts     Account[]
  categories   Category[]
  transactions Transaction[]
  goals        Goal[]

  @@map("users")
}

model Account {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  name           String        @db.VarChar(100)
  type           String        @db.VarChar(30)
  initialBalance Decimal       @map("initial_balance") @db.Decimal(12, 2)
  isActive       Boolean       @default(true) @map("is_active")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions   Transaction[]

  @@index([userId], map: "idx_accounts_user_id")
  @@map("accounts")
}

model Category {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @map("user_id") @db.Uuid
  name         String        @db.VarChar(100)
  kind         String        @db.VarChar(20)
  color        String?       @db.VarChar(20)
  icon         String?       @db.VarChar(50)
  isDefault    Boolean       @default(false) @map("is_default")
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, name, kind], map: "uq_categories_user_name_kind")
  @@index([userId], map: "idx_categories_user_id")
  @@map("categories")
}

model Transaction {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  accountId       String   @map("account_id") @db.Uuid
  categoryId      String   @map("category_id") @db.Uuid
  description     String   @db.VarChar(180)
  kind            String   @db.VarChar(20)
  amount          Decimal  @db.Decimal(12, 2)
  transactionDate DateTime @map("transaction_date") @db.Date
  notes           String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Restrict)
  category        Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  @@index([userId], map: "idx_transactions_user_id")
  @@index([accountId], map: "idx_transactions_account_id")
  @@index([categoryId], map: "idx_transactions_category_id")
  @@index([transactionDate], map: "idx_transactions_date")
  @@map("transactions")
}

model Goal {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  title        String   @db.VarChar(140)
  mode         String   @db.VarChar(20)
  targetAmount Decimal  @map("target_amount") @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_goals_user_id")
  @@map("goals")
}
